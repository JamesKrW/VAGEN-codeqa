experiment:
  dump_dir: ${ROLLOUT_DIR}
  default_max_turns: 2

run:
  backend: "vllm"
  base_seed: 0
  max_concurrent_jobs: 4
  resume: skip_completed
  live_summary: true

backends:
  vllm:
    base_url: "http://127.0.0.1:${VLLM_PORT}/v1"
    api_key: "EMPTY"
    model: "${MODEL}"
    max_concurrency: 2
    max_retries: 6
    min_backoff: 1.0
    max_backoff: 16.0
