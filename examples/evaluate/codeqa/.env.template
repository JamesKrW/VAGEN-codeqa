# CodeQA-VAGEN Configuration
# Copy this file to .env and update paths for your environment

# ── Data paths ──
# These are populated automatically by setup_data.py
# Or set manually if you have existing data
DATA_DIR=./data
DATASET_PATH=${DATA_DIR}/prepared_dataset/all_repos_dataset.jsonl
IMAGES_DIR=${DATA_DIR}/code_images_8pt
CONTAMINATED_PATH=${DATA_DIR}/contaminated_questions_v3.json
NONTRUNCATED_PATH=${DATA_DIR}/nontruncated_repos.json

# ── Output paths ──
ROLLOUT_DIR=./rollouts
LOG_DIR=./logs

# ── Model settings ──
MODEL=Qwen/Qwen3-VL-8B-Instruct
HF_HOME=${HOME}/.cache/huggingface

# ── vLLM settings ──
VLLM_PORT=8000
TENSOR_PARALLEL_SIZE=4
MAX_MODEL_LEN=50000
MAX_IMAGES_PER_PROMPT=30

# ── Conda environment name ──
CONDA_ENV=vagen
