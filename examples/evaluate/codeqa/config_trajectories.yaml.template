# CodeQA trajectory generation config (TEMPLATE)
# Generates 6 trajectories per sample with stratified ~20K token subsampling
# All trajectories see the same images per sample
# Temperature > 0 for output diversity
#
# Paths marked with ${...} are filled in by run.sh from .env

envs:
  - name: CodeQA
    n_envs: 125
    tag_id: traj_0
    split: test
    seed: [0, 124, 1]
    max_turns: 2
    config:
      dataset_path: ${DATASET_PATH}
      images_dir: ${IMAGES_DIR}
      contaminated_path: ${CONTAMINATED_PATH}
      nontruncated_path: ${NONTRUNCATED_PATH}
      subset: clean_nt
      token_budget: 20000
      trajectory_id: 0
      correct_reward: 1.0
    chat_config:
      temperature: 0.4
      max_tokens: 4096

